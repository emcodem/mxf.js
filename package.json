{
  "name": "mxf.js",
  "version": "0.1.0",
  "description": "JavaScript MXF demuxer browser plugin — hls.js-style MSE playback",
  "main": "dist/mxf.js",
  "module": "dist/mxf.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "asbuild": "asc asm/kernels.ts -o asm/build/kernels.wasm -t asm/build/kernels.wat --runtime stub -O3 --noAssert",
    "build": "vite build && vite build --config vite.worker.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:latency": "vitest run --config vitest.e2e.config.ts test/e2e/latency.test.ts",
    "serve:range": "node scripts/range-server.mjs --dir C:\\temp\\mxf.js --port 8000 --latency 0",
    "serve:range:50": "node scripts/range-server.mjs --dir C:\\temp\\mxf.js --port 8000 --latency 50",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "assemblyscript": "^0.28.18",
    "puppeteer": "^24.43.1",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "mxf",
    "demuxer",
    "broadcast",
    "mse",
    "mediasource",
    "video"
  ],
  "license": "MIT"
}
