{
  "name": "jsmxf",
  "version": "0.1.0",
  "description": "JavaScript MXF demuxer browser plugin — hls.js-style MSE playback",
  "main": "dist/jsmxf.js",
  "module": "dist/jsmxf.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "puppeteer": "^24.43.1",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "mxf",
    "demuxer",
    "broadcast",
    "mse",
    "mediasource",
    "video"
  ],
  "license": "MIT"
}
